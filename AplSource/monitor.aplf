                 :EndIf
                 :If ~cb                   ‚ćĚ No callback done, return result via TPUT
                     data ‚éēTPUT tkn
                 :EndIf
             :EndHold

         :CaseList 'Closed' 'Error'
             Log event,': ',con
             :If con‚Č°listener
                 ‚ąė‚ąė‚ąė
             :EndIf

             :Hold 'hmon'
                  cid‚Üź(conns[;1],¬Į1)[conns[;2]‚ć≥‚äācon]
                  removed‚Üź(m‚Üźcid=queue[;1])‚ĆŅqueue
                  :If cid‚Č†¬Į1
